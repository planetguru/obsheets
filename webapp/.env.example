# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials — see SETUP.md for how to create these
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of emails allowed to sign in
ALLOWED_EMAILS=coach1@gmail.com,coach2@gmail.com

# ── Claude API (document extraction) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Development only ─────────────────────────────────────────────────────────
# Set to 1 to skip Google sign-in entirely (signs you in as the dev user below).
# NEVER set this in production.
AUTH_DEV_BYPASS=
DEV_USER_NAME=Dev Coach
DEV_USER_EMAIL=dev@bridgwaterasc.local

# Set to 1 to skip the Claude API and use the bundled City of Wells fixture
# (useful for testing the wizard without an API key).
EXTRACT_MOCK=
